<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5" />
    </startup>
  <appSettings>
    <add key="Debug" value="False"/>
    <add key="Noop" value="False"/>
    <add key="Autorun" value="False"/>
    <add key="VM" value="&quot;Xubuntu 22.04&quot; {7e261a39-d356-4eb1-a8ed-75675b149241}"/>
  	<add key="ToolPath" value="%PROGRAMFILES%\oracle\virtualbox" />
  	<add key="FileName" value="VBoxManage.exe" />
  	<add key="Arguments1" value="list runningvms" />
  	<add key="Arguments2" value="guestcontrol %VM% run --username root --exe /bin/ls --/" />
  	<add key="Arguments3" value="guestcontrol %VM% run --username root --password secret --exe /bin/sh -- -c &quot;uname -a&quot;" />
    <add key="CollectInterval" value="1000"/>
    <add key="AutoAverageInterval" value="120000"/>
    <add key="Datafile" value="c:\temp\loadaverage.txt"/>
  </appSettings>
</configuration>
